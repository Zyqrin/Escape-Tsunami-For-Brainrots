-- SAFE CHARACTER
-- =====================================
local function getCharacter()
    return player.Character or player.CharacterAdded:Wait()
end

local function getHRP()
    return getCharacter():WaitForChild("HumanoidRootPart")
end

local function getHumanoid()
    return getCharacter():WaitForChild("Humanoid")
end

-- =====================================
-- SAFE MACHINE FINDER
-- =====================================
local function getMachine(name)
    local folder = workspace:FindFirstChild("SpawnMachines")
    if not folder then return nil end
    return folder:FindFirstChild(name)
end

-- =====================================
-- SUPER SCAN VARIANT
-- =====================================
local function getBrainrotName(tool)

    for _,value in pairs(tool:GetAttributes()) do
        if typeof(value) == "string" and #value > 2 then
            return value
        end
    end

    for _,v in pairs(tool:GetDescendants()) do
        if v:IsA("StringValue") and #v.Value > 2 then
            return v.Value
        end
    end

    if not string.find(tool.Name,"-") then
        return tool.Name
    end

    return nil
end

-- =====================================
-- VARIANT SYSTEM
-- =====================================
local selectedVariants = {}

local function scanVariants()
    local list = {}

    for _,tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local realName = getBrainrotName(tool)

            if realName and not table.find(list, realName) then
                table.insert(list, realName)
            end
        end
    end

    return list
end

