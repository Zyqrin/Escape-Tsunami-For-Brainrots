-- =====================================
-- MATCH SELECTED
-- =====================================
local function getMatchingBrainrots()

    local matches = {}

    for _,tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local realName = getBrainrotName(tool)

            if realName and table.find(selectedVariants, realName) then
                table.insert(matches, tool)
            end
        end
    end

    return matches
end

-- =====================================
-- TELEPORT FUNCTION (ANTI DEATH SAFE)
-- =====================================
local function teleportToMachineAndBack(machine, action)

    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        return false
    end

    local char = getCharacter()
    local hrp = getHRP()
    local humanoid = getHumanoid()

    local originalCFrame = hrp.CFrame
    local oldWalk = humanoid.WalkSpeed
    local oldJump = humanoid.JumpPower

    humanoid.WalkSpeed = 0
    humanoid.JumpPower = 0
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero

    char:PivotTo(machine:GetPivot())
    task.wait(0.3)

    local success = false
    pcall(function()
        remote:InvokeServer(action, machine)
        success = true
    end)

    task.wait(0.4)

    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        char:PivotTo(originalCFrame)
        task.wait(0.2)
        char:PivotTo(originalCFrame)
    end

    humanoid.WalkSpeed = oldWalk
    humanoid.JumpPower = oldJump

    return success
end

-- =====================================
-- COMBINE CORE (FIXED)
-- =====================================
local isCombining = false

local function runCombine(machineName)

    if isCombining then return end
    isCombining = true

    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        isCombining = false
        return
    end

    local machine = getMachine(machineName)
    if not machine then
        isCombining = false
        return
    end

    local brainrots = getMatchingBrainrots()
    if #brainrots < 3 then
        isCombining = false
        return
    end

    local humanoid = getHumanoid()
    local depositCount = 0

    for _,tool in ipairs(brainrots) do
        if depositCount >= 3 then break end
        if not player.Character then
            isCombining = false
            return
        end

        humanoid:EquipTool(tool)
        task.wait(0.3)

        local ok = teleportToMachineAndBack(machine, "Deposit")

        if ok then
            depositCount += 1
            print("📦 Deposit ke:", depositCount)
        end

        task.wait(0.8)
    end

    print("📊 Total Deposit:", depositCount)

    if depositCount == 3 then
        teleportToMachineAndBack(machine, "Combine")
        print("✅ Combine Confirmed ->", machineName)

        print("⏳ Waiting 25 seconds...")
        task.wait(25)
    else
        print("❌ Deposit kurang dari 3, batal confirm")
    end

    isCombining = false
end

